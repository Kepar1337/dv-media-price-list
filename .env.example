# ──────────────────────────────────────────────────────────────────────────
# DV Media Group — приклад env-змінних
# Скопіюйте у `.env.local` (для локальної розробки) та додайте у Vercel
# Dashboard → Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────

# Канонічний URL сайту (без слешу в кінці).
# Vercel автоматично виставить NEXT_PUBLIC_VERCEL_URL — це fallback.
NEXT_PUBLIC_SITE_URL=https://dv-price-list.vercel.app

# ── Telegram bot для отримання заявок з форми ──
# Створити бота: @BotFather → /newbot. Отримаєте токен.
# Дізнатись chat_id: написати боту /start, відкрити
# https://api.telegram.org/bot<TOKEN>/getUpdates → chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Sheets для логування заявок ──
# 1. Створити service-account у Google Cloud Console.
# 2. Завантажити JSON-ключ → скопіювати client_email і private_key.
# 3. Поділитись таблицею з client_email (роль "Editor").
# 4. GOOGLE_SHEETS_SPREADSHEET_ID — це частина URL таблиці.
# Уважно: private_key містить \n — зберігайте з лапками.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
# Назва аркуша всередині таблиці (за замовчуванням — Leads).
GOOGLE_SHEETS_SHEET_NAME=Leads
