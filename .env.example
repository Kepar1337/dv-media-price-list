# ──────────────────────────────────────────────────────────────────────────
# DV Media Group — приклад env-змінних
# Скопіюйте у `.env.local` (для локальної розробки) та додайте у Vercel
# Dashboard → Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────

# Канонічний URL сайту (без слешу в кінці).
# Vercel автоматично виставить NEXT_PUBLIC_VERCEL_URL — це fallback.
NEXT_PUBLIC_SITE_URL=https://dv-price-list.vercel.app

# ── Telegram bot для отримання заявок з форми ──
# Створити бота: @BotFather → /newbot. Отримаєте токен.
# Дізнатись chat_id: написати боту /start, відкрити
# https://api.telegram.org/bot<TOKEN>/getUpdates → chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notion для логування заявок ──
# 1. Створити internal integration: https://www.notion.so/profile/integrations
#    → скопіювати "Internal Integration Secret" у NOTION_API_KEY.
# 2. Створити Database у Notion з properties:
#      Name       (title)
#      Contact    (text)
#      Channels   (text)
#      Format     (text)
#      Message    (text)
#      Submitted  (date)
# 3. У базі: "..." → Connections → додати створену integration.
# 4. NOTION_DATABASE_ID — UUID у URL бази (32 символи hex з/без дефісів).
NOTION_API_KEY=
NOTION_DATABASE_ID=
